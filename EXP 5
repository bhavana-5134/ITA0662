from sklearn.neighbors import KNeighborsClassifier

# Training data
X = [[1], [2], [3], [6], [7], [8]]
y = ['A', 'A', 'A', 'B', 'B', 'B']

# Create model
knn = KNeighborsClassifier(n_neighbors=3)

# Train model
knn.fit(X, y)

# Test data
test = [[5]]

# Prediction
result = knn.predict(test)

print("Predicted Class:", result[0])
